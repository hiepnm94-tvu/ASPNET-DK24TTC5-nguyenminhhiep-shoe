@{
    ViewData["Title"] = "Hoàn tất đơn hàng";
    var order = ViewBag.Order as Order;
}

<div class="breadcrumbs">
    <div class="container">
        <div class="row">
            <div class="col">
                <p class="bread">
                    <span><a asp-controller="Home" asp-action="Index">Trang chủ</a></span>
                    <span>Hoàn tất đơn hàng</span>
                </p>
            </div>
        </div>
    </div>
</div>

<div class="colorlib-product">
    <div class="container">
        <div class="row row-pb-lg">
            <div class="col-sm-10 offset-md-1">
                <div class="process-wrap">
                    <div class="process text-center active">
                        <p><span>01</span></p>
                        <h3>Giỏ hàng</h3>
                    </div>
                    <div class="process text-center active">
                        <p><span>02</span></p>
                        <h3>Thanh toán</h3>
                    </div>
                    <div class="process text-center active">
                        <p><span>03</span></p>
                        <h3>Hoàn tất</h3>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-10 offset-md-1 text-center">
                <span class="icon-addcart">
                    <span><i class="icon-check"></i></span>
                </span>
                <h2 class="mb-3">Cảm ơn bạn đã đặt hàng!</h2>
                @if (order != null && !string.IsNullOrWhiteSpace(order.OrderCode))
                {
                    <p class="lead">
                        Mã đơn hàng: <strong>@order.OrderCode</strong>
                    </p>
                    <p class="text-muted">
                        Tổng thanh toán: <strong>@order.TotalAmount.ToString("N0") đ</strong>
                    </p>
                }
                <p class="mt-4">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mr-2 mb-2">Trang chủ</a>
                    <a asp-controller="Product" asp-action="Category" class="btn btn-primary mb-2">Tiếp tục mua sắm</a>
                </p>
            </div>
        </div>
    </div>
</div>
