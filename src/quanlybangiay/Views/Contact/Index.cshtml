@{
    ViewData["Title"] = "Liên hệ";
    var setting = ViewBag.Setting as Setting;
    var successMessage = TempData["SuccessMessage"] as string;
    var errorMessage = TempData["ErrorMessage"] as string;
}

<div class="breadcrumbs">
    <div class="container">
        <div class="row">
            <div class="col">
                <p class="bread">
                    <span><a asp-controller="Home" asp-action="Index">Trang chủ</a></span>
                    <span>Liên hệ</span>
                </p>
            </div>
        </div>
    </div>
</div>

<div id="colorlib-contact">
    <div class="container">
        <div class="row">
            <div class="col-sm-12">
                <h3>Thông tin liên hệ</h3>
                <div class="row contact-info-wrap">
                    <div class="col-md-3">
                        <p><span><i class="icon-location"></i></span> @(setting?.Address ?? "...")</p>
                    </div>
                    <div class="col-md-3">
                        <p>
                            <span><i class="icon-phone3"></i></span>
                            @if (!string.IsNullOrWhiteSpace(setting?.Phone))
                            {
                                <a href="tel:@setting.Phone">@setting.Phone</a>
                            }
                            else
                            {
                                <span>...</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-3">
                        <p>
                            <span><i class="icon-paperplane"></i></span>
                            @if (!string.IsNullOrWhiteSpace(setting?.Email))
                            {
                                <a href="mailto:@setting.Email">@setting.Email</a>
                            }
                            else
                            {
                                <span>...</span>
                            }
                        </p>
                    </div>
                    <div class="col-md-3">
                        <p>
                            <span><i class="icon-globe"></i></span>
                            <a asp-controller="Home" asp-action="Index">@(setting?.ShopName ?? "Shop Giày")</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="contact-wrap">
                    @if (!string.IsNullOrEmpty(successMessage))
                    {
                        <div class="alert alert-success" role="alert">@successMessage</div>
                    }
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">@errorMessage</div>
                    }

                    <h3>Liên hệ với chúng tôi</h3>
                    <form asp-controller="Contact" asp-action="Submit" method="post" asp-antiforgery="false" class="contact-form">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="lastName">Họ</label>
                                    <input type="text" id="lastName" name="lastName" class="form-control" placeholder="Vui lòng nhập họ" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="firstName">Tên</label>
                                    <input type="text" id="firstName" name="firstName" class="form-control" placeholder="Vui lòng nhập tên" required />
                                </div>
                            </div>
                        </div>
                        <div class="form-group">
                            <label for="email">Email</label>
                            <input type="email" id="email" name="email" class="form-control" placeholder="Vui lòng nhập email" required style="height: 44px !important"/>
                        </div>
                        <div class="form-group">
                            <label for="subject">Tiêu đề</label>
                            <input type="text" id="subject" name="subject" class="form-control" placeholder="Vui lòng nhập tiêu đề" />
                        </div>
                        <div class="form-group">
                            <label for="message">Nội dung</label>
                            <textarea id="message" name="message" class="form-control" cols="30" rows="10" placeholder="Nội dung tin nhắn" required></textarea>
                        </div>
                        <div class="form-group">
                            <input type="submit" value="Gửi tin nhắn" class="btn btn-primary btn-modify" />
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-6">
                <div id="map" class="d-flex align-items-center justify-content-center bg-light text-muted">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3919.5215160968523!2d106.70038339999999!3d10.7713115!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31752f40989fd83d%3A0x9eba98ec8ea81ce!2zSGF2YW5hIFRvd2VyLCAxMzIgSMOgbSBOZ2hpLCBC4bq_biBUaMOgbmgsIEjhu5MgQ2jDrSBNaW5oLCBWaeG7h3QgTmFt!5e0!3m2!1svi!2s!4v1775109660326!5m2!1svi!2s" style="border:0; width: 100%; height: 100%" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
        </div>
    </div>
</div>
