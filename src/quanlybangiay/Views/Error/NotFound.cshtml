@{
    ViewData["Title"] = "404 - Không tìm thấy trang";
}

<div class="breadcrumbs">
    <div class="container">
        <div class="row">
            <div class="col">
                <p class="bread">
                    <span><a asp-controller="Home" asp-action="Index">Trang chủ</a></span>
                    <span>404</span>
                </p>
            </div>
        </div>
    </div>
</div>

<section class="ftco-section" style="padding: 6rem 0;">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-md-8">
                <div style="font-size:9rem; font-weight:700; line-height:1; color:#e8e8e8; letter-spacing:-4px;">404</div>
                <h2 style="margin-top:-1rem; margin-bottom:1rem;">Không tìm thấy trang</h2>
                <p class="text-muted mb-4">
                    Trang bạn đang tìm kiếm không tồn tại hoặc đã bị di chuyển.<br />
                    Hãy kiểm tra lại địa chỉ URL hoặc quay về trang chủ.
                </p>
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary px-4 me-2">
                    <i class="ion-ios-home"></i> Về trang chủ
                </a>
                <button onclick="history.back()" class="btn btn-outline-secondary px-4">
                    <i class="ion-ios-arrow-back"></i> Quay lại
                </button>
            </div>
        </div>
    </div>
</section>
