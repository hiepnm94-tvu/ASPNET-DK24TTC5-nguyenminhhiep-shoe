@using Microsoft.EntityFrameworkCore
@inject quanlybangiay.Data.ApplicationDbContext Db
@{
    var categories = await Db.Categories
        .Where(c => c.IsActive == true)
        .OrderBy(c => c.CategoryName)
        .AsNoTracking()
        .ToListAsync();

    var setting = await Db.Settings.AsNoTracking().FirstOrDefaultAsync();
    var shopName = setting?.ShopName ?? "Shoe Store";

    var cartJson = Context.Session.GetString("ShoppingCart");
    var cartCount = 0;
    if (!string.IsNullOrEmpty(cartJson))
    {
        try
        {
            var items = System.Text.Json.JsonSerializer.Deserialize<List<quanlybangiay.Models.ViewModels.CartItem>>(cartJson);
            cartCount = items?.Sum(i => i.Quantity) ?? 0;
        }
        catch { }
    }
}
<nav class="colorlib-nav" role="navigation">
    <div class="top-menu">
        <div class="container">
            <div class="row">
                <div class="col-sm-7 col-md-9">
                    <div id="colorlib-logo"><a asp-controller="Home" asp-action="Index">@shopName</a></div>
                </div>
                <div class="col-sm-5 col-md-3">
                    <form action="/tim-kiem" method="get" class="search-wrap">
                        <div class="form-group">
                            <input type="search" name="q" class="form-control search" placeholder="Tìm kiếm sản phẩm...">
                            <button class="btn btn-primary submit-search text-center" type="submit"><i class="icon-search"></i></button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-12 text-left menu-1">
                    <ul>
                        <li><a href="/">Trang chủ</a></li>
                        @foreach (var cat in categories)
                        {
                            var catUrl = !string.IsNullOrWhiteSpace(cat.Slug)
                                ? $"/danh-muc/{cat.Slug}"
                                : Url.Action("Category", "Product", new { id = cat.CategoryId });
                            <li><a href="@catUrl">@cat.CategoryName</a></li>
                        }
                        <li><a href="/lien-he">Liên hệ</a></li>
                        <li class="cart">
                            <a href="/gio-hang">
                                <i class="icon-shopping-cart"></i> Giỏ hàng [<span id="cart-count">@cartCount</span>]
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</nav>
