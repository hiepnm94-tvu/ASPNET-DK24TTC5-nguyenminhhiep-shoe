@{
    ViewData["Title"] = "Trang chủ";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var bestSellers = ViewBag.BestSellers as List<Product> ?? new List<Product>();
    var featuredCategories = categories.Take(2).ToList();
    var featuredImages = new[] { "/images/men.jpg", "/images/women.jpg" };
}

<aside id="colorlib-hero">
    <div class="flexslider">
        <ul class="slides">
            <li style="background-image: url('/images/img_bg_1.jpg');">
                <div class="overlay"></div>
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6 offset-sm-3 text-center slider-text">
                            <div class="slider-text-inner">
                                <div class="desc">
                                    <h1 class="head-1">Men's</h1>
                                    <h2 class="head-2">Shoes</h2>
                                    <h2 class="head-3">Collection</h2>
                                    <p class="category"><span>Xu hướng giày mới</span></p>
                                    <p><a asp-controller="Product" asp-action="Category" class="btn btn-primary">Mua sắm</a></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
            <li style="background-image: url('/images/img_bg_2.jpg');">
                <div class="overlay"></div>
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6 offset-sm-3 text-center slider-text">
                            <div class="slider-text-inner">
                                <div class="desc">
                                    <h1 class="head-1">Huge</h1>
                                    <h2 class="head-2">Sale</h2>
                                    <h2 class="head-3"><strong class="font-weight-bold">50%</strong> Off</h2>
                                    <p class="category"><span>Ưu đãi sandal &amp; dép</span></p>
                                    <p><a asp-controller="Product" asp-action="Category" class="btn btn-primary">Mua sắm</a></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
            <li style="background-image: url('/images/img_bg_3.jpg');">
                <div class="overlay"></div>
                <div class="container-fluid">
                    <div class="row">
                        <div class="col-sm-6 offset-sm-3 text-center slider-text">
                            <div class="slider-text-inner">
                                <div class="desc">
                                    <h1 class="head-1">New</h1>
                                    <h2 class="head-2">Arrival</h2>
                                    <h2 class="head-3">up to <strong class="font-weight-bold">30%</strong> off</h2>
                                    <p class="category"><span>Giày nam nữ mới về</span></p>
                                    <p><a asp-controller="Product" asp-action="Category" class="btn btn-primary">Mua sắm</a></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </li>
        </ul>
    </div>
</aside>

<div class="colorlib-intro">
    <div class="container">
        <div class="row">
            <div class="col-sm-12 text-center">
                <h2 class="intro">Ý tưởng đơn giản: mang đến giày dép chất lượng, thiết đẹp — những gì chúng tôi cũng muốn mang mỗi ngày.</h2>
            </div>
        </div>
    </div>
</div>

<div class="colorlib-product">
    <div class="container-fluid">
        <div class="row">
            @for (var i = 0; i < featuredCategories.Count; i++)
            {
                var cat = featuredCategories[i];
                var bg = i < featuredImages.Length ? featuredImages[i] : "/images/men.jpg";
                <div class="col-sm-6 text-center">
                    <div class="featured">
                        <a asp-controller="Product" asp-action="Category" asp-route-id="@cat.CategoryId" class="featured-img" style="background-image: url('@bg');"></a>
                        <div class="desc">
                            <h2><a asp-controller="Product" asp-action="Category" asp-route-id="@cat.CategoryId">@cat.CategoryName</a></h2>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<div class="colorlib-product">
    <div class="container">
        <div class="row">
            <div class="col-sm-8 offset-sm-2 text-center colorlib-heading">
                <h2>Sản phẩm bán chạy nhất</h2>
            </div>
        </div>
        <div class="row row-pb-md">
            @{
                var n = 0;
            }
            @foreach (var product in bestSellers)
            {
                n++;
                var thumb = string.IsNullOrWhiteSpace(product.ThumbnailUrl)
                    ? "/images/no-image.png"
                    : product.ThumbnailUrl;
                var hasDiscount = product.DiscountPrice.HasValue && product.DiscountPrice.Value > 0
                    && product.DiscountPrice.Value < product.BasePrice;
                <div class="col-lg-3 mb-4 text-center">
                    <div class="product-entry border">
                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId" class="prod-img">
                            <img src="@thumb" class="img-fluid" alt="@product.ProductName">
                        </a>
                        <div class="desc">
                            <h2><a asp-controller="Product" asp-action="Detail" asp-route-id="@product.ProductId">@product.ProductName</a></h2>
                            <span class="price">
                                @if (hasDiscount)
                                {
                                    <del>@product.BasePrice.ToString("N0") đ</del>
                                    <text> </text>
                                    @product.DiscountPrice!.Value.ToString("N0")<text> đ</text>
                                }
                                else
                                {
                                    @product.BasePrice.ToString("N0")<text> đ</text>
                                }
                            </span>
                        </div>
                    </div>
                </div>
                @if (n % 4 == 0 && n < bestSellers.Count)
                {
                    <div class="w-100"></div>
                }
            }
        </div>
        <div class="row">
            <div class="col-md-12 text-center">
                <p><a asp-controller="Product" asp-action="Category" class="btn btn-primary btn-lg">Shop All Products</a></p>
            </div>
        </div>
    </div>
</div>
