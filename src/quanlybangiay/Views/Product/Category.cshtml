@model IEnumerable<quanlybangiay.Models.Product>
@{
    var categories = ViewBag.Categories as IList<Category> ?? new List<Category>();
    var currentCategory = ViewBag.CurrentCategory as Category;
    var categoryId = ViewBag.CategoryId as int?;
    var categorySlug = ViewBag.CategorySlug as string;
    var page = ViewBag.Page is int pg ? pg : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 0;
    var bannerTitle = currentCategory?.CategoryName ?? "Sản phẩm";
    var backgroundImage = "/images/men.jpg";
    if (currentCategory?.CategoryId == 1) // Nam
    {
        backgroundImage = "/images/men.jpg";
    }
    else if (currentCategory?.CategoryId == 2) // Nữ
    {
        backgroundImage = "/images/cover-img-1.jpg";
    }
    else if (currentCategory?.CategoryId == 3) // Trẻ em
    {
        backgroundImage = "/images/shoe-sports.jpg";
    }
    ViewData["Title"] = bannerTitle;
}

<div class="container">
    <div class="row">
        <div class="col">
            <div class="breadcrumbs">
                <p class="bread">
                    <span><a href="/">Trang chủ</a></span> /
                    <span><a href="/san-pham">Sản phẩm</a></span>
                    @if (currentCategory != null)
                    {
                        <text> / </text>
                        <span>@currentCategory.CategoryName</span>
                    }
                </p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row">
        <div class="col">
            <div class="breadcrumbs-img" style="background-image: url('@backgroundImage');">
                <div class="desc">
                    <h2 class="text-hide">@bannerTitle</h2>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="container">
    <div class="menu text-center">
        <p>
            <a href="/san-pham" class="@(!categoryId.HasValue ? "font-weight-bold" : "")">Tất cả</a>
            @foreach (var c in categories)
            {
                var cUrl = !string.IsNullOrWhiteSpace(c.Slug) ? $"/danh-muc/{c.Slug}" : Url.Action("Category", "Product", new { id = c.CategoryId });
                <a href="@cUrl" class="@(categoryId == c.CategoryId ? "font-weight-bold" : "")">@c.CategoryName</a>
            }
        </p>
    </div>
</div>

<div class="colorlib-product">
    <div class="container">
        @if (Model == null || !Model.Any())
        {
            <div class="row">
                <div class="col-12 text-center py-5">
                    <p class="lead mb-0">Không có sản phẩm nào</p>
                </div>
            </div>
        }
        else
        {
            var basePageUrl = !string.IsNullOrWhiteSpace(categorySlug) ? $"/danh-muc/{categorySlug}" : "/san-pham";
            
            <div class="row">
                @foreach (var p in Model)
                {
                    var prdUrl = !string.IsNullOrWhiteSpace(p.Slug)
                        ? $"/san-pham/{p.Slug}"
                        : Url.Action("Detail", "Product", new { id = p.ProductId });
                    <div class="col-md-3 col-lg-3 mb-4 text-center">
                        <div class="product-entry border">
                            <a href="@prdUrl" class="prod-img">
                                <img src="@(p.ThumbnailUrl ?? "/images/no-image.png")" class="img-fluid" alt="@p.ProductName">
                            </a>
                            <div class="desc">
                                <h2><a href="@prdUrl">@p.ProductName</a></h2>
                                @if (p.DiscountPrice.HasValue)
                                {
                                    <span class="price">@p.DiscountPrice.Value.ToString("N0") đ</span>
                                    <span class="price" style="text-decoration: line-through; opacity: 0.55; font-size: 15px;">@p.BasePrice.ToString("N0") đ</span>
                                }
                                else
                                {
                                    <span class="price">@p.BasePrice.ToString("N0") đ</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="row">
                    <div class="col-md-12 text-center">
                        <div class="block-27">
                            <ul>
                                @if (page > 1)
                                {
                                    <li><a href="@basePageUrl?page=@(page - 1)"><i class="ion-ios-arrow-back"></i></a></li>
                                }
                                @for (var i = 1; i <= totalPages; i++)
                                {
                                    <li class="@(i == page ? "active" : null)">
                                        @if (i == page)
                                        {
                                            <span>@i</span>
                                        }
                                        else
                                        {
                                            <a href="@basePageUrl?page=@i">@i</a>
                                        }
                                    </li>
                                }
                                @if (page < totalPages)
                                {
                                    <li><a href="@basePageUrl?page=@(page + 1)"><i class="ion-ios-arrow-forward"></i></a></li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
