@model IEnumerable<quanlybangiay.Models.Product>
@{
    var categories = ViewBag.Categories as IList<Category> ?? new List<Category>();
    var currentCategory = ViewBag.CurrentCategory as Category;
    var categoryId = ViewBag.CategoryId as int?;
    var page = ViewBag.Page is int pg ? pg : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 0;
    var bannerTitle = currentCategory?.CategoryName ?? "Sản phẩm";
    ViewData["Title"] = bannerTitle;
}

<div class="breadcrumbs">
    <div class="container">
        <div class="row">
            <div class="col">
                <p class="bread">
                    <span><a asp-controller="Home" asp-action="Index">Trang chủ</a></span>
                    <span>@bannerTitle</span>
                </p>
            </div>
        </div>
    </div>
</div>

<div class="breadcrumbs-img" style="background-image: url('/images/men.jpg');">
    <div class="container">
        <div class="row">
            <div class="col-sm-12 text-center">
                <div class="desc">
                    <h2>@bannerTitle</h2>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="menu text-center">
        <p>
            <a asp-controller="Product" asp-action="Category" class="@(!categoryId.HasValue ? "font-weight-bold" : "")">Tất cả</a>
            @foreach (var c in categories)
            {
                <a asp-controller="Product" asp-action="Category" asp-route-id="@c.CategoryId" class="@(categoryId == c.CategoryId ? "font-weight-bold" : "")">@c.CategoryName</a>
            }
        </p>
    </div>
</div>

<div class="colorlib-product">
    <div class="container">
        @if (Model == null || !Model.Any())
        {
            <div class="row">
                <div class="col-12 text-center py-5">
                    <p class="lead mb-0">Không có sản phẩm nào</p>
                </div>
            </div>
        }
        else
        {
            <div class="row row-pb-md">
                @foreach (var p in Model)
                {
                    <div class="col-md-3 col-lg-3 mb-4 text-center">
                        <div class="product-entry border">
                            <a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductId" class="prod-img">
                                <img src="@(p.ThumbnailUrl ?? "/images/no-image.png")" class="img-fluid" alt="@p.ProductName">
                            </a>
                            <div class="desc">
                                <h2><a asp-controller="Product" asp-action="Detail" asp-route-id="@p.ProductId">@p.ProductName</a></h2>
                                @if (p.DiscountPrice.HasValue)
                                {
                                    <span class="price">@p.DiscountPrice.Value.ToString("N0") đ</span>
                                    <span class="price" style="text-decoration: line-through; opacity: 0.55; font-size: 15px;">@p.BasePrice.ToString("N0") đ</span>
                                }
                                else
                                {
                                    <span class="price">@p.BasePrice.ToString("N0") đ</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (totalPages > 1)
            {
                <div class="row">
                    <div class="col-md-12 text-center">
                        <div class="block-27">
                            <ul>
                                @if (page > 1)
                                {
                                    <li>
                                        <a asp-controller="Product" asp-action="Category" asp-route-id="@categoryId" asp-route-page="@(page - 1)"><i class="ion-ios-arrow-back"></i></a>
                                    </li>
                                }
                                @for (var i = 1; i <= totalPages; i++)
                                {
                                    <li class="@(i == page ? "active" : null)">
                                        @if (i == page)
                                        {
                                            <span>@i</span>
                                        }
                                        else
                                        {
                                            <a asp-controller="Product" asp-action="Category" asp-route-id="@categoryId" asp-route-page="@i">@i</a>
                                        }
                                    </li>
                                }
                                @if (page < totalPages)
                                {
                                    <li>
                                        <a asp-controller="Product" asp-action="Category" asp-route-id="@categoryId" asp-route-page="@(page + 1)"><i class="ion-ios-arrow-forward"></i></a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
