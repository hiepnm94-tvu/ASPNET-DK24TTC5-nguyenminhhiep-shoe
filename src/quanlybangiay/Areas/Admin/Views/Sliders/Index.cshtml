@model IEnumerable<quanlybangiay.Models.Slider>
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Quản lý Slider";
}

<div class="card">
    <div class="d-flex justify-content-between align-items-center card-header mb-3">
        <h2>Quản lý Slider</h2>
        <a asp-area="Admin" asp-controller="Sliders" asp-action="Create" class="btn btn-primary btn-ad-create">Tạo mới</a>
    </div>

    <div class="table-responsive text-nowrap">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Hình ảnh</th>
                    <th>Tiêu đề</th>
                    <th>Thứ tự</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SliderId</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(item.Image))
                                {
                                    <img src="@item.Image" alt="Slider" style="max-height:50px;max-width:120px;border-radius:4px;" />
                                }
                            </td>
                            <td>@item.Title</td>
                            <td>@item.SortOrder</td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-label-primary" : "bg-label-dark") me-1">@(item.IsActive ? "Hiển thị" : "Ẩn")</span>
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-area="Admin" asp-controller="Sliders" asp-action="Details" asp-route-id="@item.SliderId" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-area="Admin" asp-controller="Sliders" asp-action="Edit" asp-route-id="@item.SliderId" class="btn btn-sm btn-secondary">Sửa</a>
                                <form asp-area="Admin" asp-controller="Sliders" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.SliderId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa slider này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_Pagination.cshtml")
</div>
