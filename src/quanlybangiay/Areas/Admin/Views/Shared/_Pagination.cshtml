@{
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 20;
    int totalCount = ViewBag.TotalCount ?? 0;
    int totalPages = ViewBag.TotalPages ?? 1;
    bool hasPrev = page > 1;
    bool hasNext = page < totalPages;
    string controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentQuery = ViewContext.HttpContext.Request.Query;
    string extraParams = "";
    foreach (var q in currentQuery)
    {
        if (q.Key != "page" && q.Key != "pageSize")
        {
            extraParams += $"&{q.Key}={q.Value}";
        }
    }
}

<div class="d-flex justify-content-between align-items-center flex-wrap mt-3 px-3 pb-3">
    <div class="d-flex align-items-center gap-2">
        <label class="form-label mb-0 text-nowrap">Hiển thị</label>
        <select class="form-select form-select-sm" style="width:auto;" onchange="window.location.href='?page=1&pageSize='+this.value+'@Html.Raw(extraParams)'">
            <option value="10" selected="@(pageSize == 10)">10</option>
            <option value="20" selected="@(pageSize == 20)">20</option>
            <option value="50" selected="@(pageSize == 50)">50</option>
            <option value="0" selected="@(pageSize == 0)">Tất cả</option>
        </select>
        <span class="text-muted text-nowrap">/ @totalCount mục</span>
    </div>

    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm mb-0 mt-2 mt-md-0">
                <li class="page-item @(hasPrev ? "" : "disabled")">
                    <a class="page-link" href="?page=1&pageSize=@pageSize@Html.Raw(extraParams)">«</a>
                </li>
                <li class="page-item @(hasPrev ? "" : "disabled")">
                    <a class="page-link" href="?page=@(page - 1)&pageSize=@pageSize@Html.Raw(extraParams)">‹</a>
                </li>

                @{
                    int startPage = Math.Max(1, page - 2);
                    int endPage = Math.Min(totalPages, page + 2);
                    if (startPage > 1)
                    {
                        <li class="page-item"><a class="page-link" href="?page=1&pageSize=@pageSize@Html.Raw(extraParams)">1</a></li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                    }
                    for (int i = startPage; i <= endPage; i++)
                    {
                        <li class="page-item @(i == page ? "active" : "")">
                            <a class="page-link" href="?page=@i&pageSize=@pageSize@Html.Raw(extraParams)">@i</a>
                        </li>
                    }
                    if (endPage < totalPages)
                    {
                        if (endPage < totalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">…</span></li>
                        }
                        <li class="page-item"><a class="page-link" href="?page=@totalPages&pageSize=@pageSize@Html.Raw(extraParams)">@totalPages</a></li>
                    }
                }

                <li class="page-item @(hasNext ? "" : "disabled")">
                    <a class="page-link" href="?page=@(page + 1)&pageSize=@pageSize@Html.Raw(extraParams)">›</a>
                </li>
                <li class="page-item @(hasNext ? "" : "disabled")">
                    <a class="page-link" href="?page=@totalPages&pageSize=@pageSize@Html.Raw(extraParams)">»</a>
                </li>
            </ul>
        </nav>
    }
</div>
