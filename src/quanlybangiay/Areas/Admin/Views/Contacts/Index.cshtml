@model IEnumerable<quanlybangiay.Models.Contact>
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Quản lý liên hệ";
}

<div class="card">
    <div class="d-flex justify-content-between align-items-center card-header mb-3">
        <h2>Quản lý liên hệ</h2>
    </div>

    <div class="table-responsive text-nowrap">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Chủ đề</th>
                    <th>IP</th>
                    <th>Trạng thái</th>
                    <th>Ngày gửi</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ContactId</td>
                            <td>@item.FirstName @item.LastName</td>
                            <td>@item.Email</td>
                            <td class="text-wrap" style="max-width:200px;">@item.Subject</td>
                            <td><code>@(item.IP ?? "—")</code></td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-label-warning" : "bg-label-success") me-1">@(item.IsActive ? "Chờ xử lý" : "Đã xử lý")</span>
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-area="Admin" asp-controller="Contacts" asp-action="Details" asp-route-id="@item.ContactId" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-area="Admin" asp-controller="Contacts" asp-action="Edit" asp-route-id="@item.ContactId" class="btn btn-sm btn-secondary">Xử lý</a>
                                <form asp-area="Admin" asp-controller="Contacts" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ContactId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa liên hệ này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center py-4 text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_Pagination.cshtml")
</div>
