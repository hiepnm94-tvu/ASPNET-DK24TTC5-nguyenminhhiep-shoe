@model quanlybangiay.Models.Contact
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Chi tiết liên hệ";
}

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h2 class="mb-0">Chi tiết liên hệ #@Model.ContactId</h2>
        <span class="badge @(Model.IsActive ? "bg-label-warning" : "bg-label-success") fs-6">@(Model.IsActive ? "Chờ xử lý" : "Đã xử lý")</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <table class="table table-borderless">
                    <tr>
                        <th class="text-muted" style="width:140px;">Họ</th>
                        <td>@(Model.FirstName ?? "—")</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Tên</th>
                        <td>@(Model.LastName ?? "—")</td>
                    </tr>
                    <tr>
                        <th class="text-muted">Email</th>
                        <td><a href="mailto:@Model.Email">@(Model.Email ?? "—")</a></td>
                    </tr>
                    <tr>
                        <th class="text-muted">IP</th>
                        <td><code>@(Model.IP ?? "—")</code></td>
                    </tr>
                    <tr>
                        <th class="text-muted">Ngày gửi</th>
                        <td>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    </tr>
                </table>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Chủ đề</label>
                    <p class="fw-semibold">@(Model.Subject ?? "—")</p>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold text-muted">Nội dung</label>
                    <div class="p-3 bg-light rounded" style="white-space:pre-wrap;">@(Model.Message ?? "—")</div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Note))
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-muted">Ghi chú Admin</label>
                        <div class="p-3 bg-light rounded border-start border-3 border-primary" style="white-space:pre-wrap;">@Model.Note</div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="card-footer">
        <a asp-area="Admin" asp-controller="Contacts" asp-action="Edit" asp-route-id="@Model.ContactId" class="btn btn-primary">Xử lý</a>
        <a asp-area="Admin" asp-controller="Contacts" asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
    </div>
</div>
