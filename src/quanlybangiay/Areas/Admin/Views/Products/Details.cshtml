@model quanlybangiay.Models.Product
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Chi tiết sản phẩm";
    var variants = ViewBag.Variants as List<quanlybangiay.Models.ProductVariant> ?? new List<quanlybangiay.Models.ProductVariant>();
}

<div class="card mb-4">
    <h2 class="card-header fw-bold py-3 mb-4">Chi tiết sản phẩm</h2>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                @if (!string.IsNullOrEmpty(Model.ThumbnailUrl))
                {
                    <img src="@Model.ThumbnailUrl" alt="Thumbnail" class="img-fluid rounded mb-3" />
                }
            </div>
            <div class="col-md-8">
                <div class="mb-3">
                    <label class="form-label fw-bold">ID</label>
                    <div>@Model.ProductId</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên sản phẩm</label>
                    <div>@Model.ProductName</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Slug</label>
                    <div>@Model.Slug</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Chuyên mục</label>
                    <div>@Model.Category?.CategoryName</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Thương hiệu</label>
                    <div>@(Model.Brand ?? "—")</div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá gốc</label>
                        <div>@Model.BasePrice.ToString("N0") ₫</div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Giá khuyến mãi</label>
                        <div>@(Model.DiscountPrice?.ToString("N0") ?? "—") ₫</div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Trạng thái</label>
                    <div>
                        @{
                            var statusText = Model.Status switch { 1 => "Hoạt động", 0 => "Ẩn", _ => "Nháp" };
                            var statusClass = Model.Status switch { 1 => "bg-label-primary", 0 => "bg-label-dark", _ => "bg-label-warning" };
                        }
                        <span class="badge @statusClass">@statusText</span>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ngày tạo</label>
                    <div>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ngày cập nhật</label>
                    <div>@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ShortDescription))
        {
            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả ngắn</label>
                <div>@Model.ShortDescription</div>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="mb-3">
                <label class="form-label fw-bold">Mô tả chi tiết</label>
                <div>@Html.Raw(Model.Description)</div>
            </div>
        }
    </div>
</div>

<div class="card mb-4">
    <div class="d-flex justify-content-between align-items-center card-header">
        <h5 class="fw-bold py-3 mb-0">Biến thể sản phẩm</h5>
        <div>
            <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Index" asp-route-productId="@Model.ProductId" class="btn btn-sm btn-outline-primary me-1">Xem tất cả</a>
            <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Create" asp-route-productId="@Model.ProductId" class="btn btn-sm btn-primary">Thêm biến thể</a>
        </div>
    </div>
    <div class="table-responsive text-nowrap">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>SKU</th>
                    <th>Size</th>
                    <th>Màu</th>
                    <th>Mã màu</th>
                    <th>Tồn kho</th>
                    <th>Giá thêm</th>
                    <th>Trọng lượng (g)</th>
                    <th>Mặc định</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (variants.Any())
                {
                    @foreach (var v in variants)
                    {
                        <tr>
                            <td><strong>@v.SKU</strong></td>
                            <td>@(v.SizeValue ?? "—")</td>
                            <td>@(v.ColorName ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(v.ColorCode))
                                {
                                    <span style="display:inline-block;width:18px;height:18px;background:@v.ColorCode;border:1px solid #ccc;border-radius:3px;vertical-align:middle;"></span>
                                    @v.ColorCode
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>
                            <td>@v.StockQty</td>
                            <td>@(v.AdditionalPrice?.ToString("N0") ?? "0") ₫</td>
                            <td>@(v.WeightGram?.ToString() ?? "—")</td>
                            <td>
                                <span class="badge @(v.IsDefault ? "bg-label-primary" : "bg-label-dark")">@(v.IsDefault ? "Có" : "Không")</span>
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Edit" asp-route-id="@v.VariantId" class="btn btn-sm btn-secondary">Sửa</a>
                                <form asp-area="Admin" asp-controller="ProductVariants" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@v.VariantId" />
                                    <input type="hidden" name="productId" value="@Model.ProductId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa biến thể này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">Chưa có biến thể nào</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-secondary">Sửa</a>
<a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
