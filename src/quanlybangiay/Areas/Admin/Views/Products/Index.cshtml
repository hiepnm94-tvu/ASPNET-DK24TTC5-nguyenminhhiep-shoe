@model IEnumerable<quanlybangiay.Models.Product>
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Quản lý sản phẩm";

    int? searchProductId = ViewBag.SearchProductId as int?;
    var searchSku = ViewBag.SearchSku as string;
    var searchProductName = ViewBag.SearchProductName as string;
    byte? searchStatus = ViewBag.SearchStatus as byte?;
}

<div class="card">
    <div class="d-flex justify-content-between align-items-center card-header mb-0">
        <h2>Quản lý sản phẩm</h2>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn btn-primary btn-ad-create">Tạo mới</a>
    </div>

    <div class="card-body pb-0">
        <form method="get" asp-area="Admin" asp-controller="Products" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">ID sản phẩm</label>
                    <input type="number" name="productId" class="form-control form-control-sm" value="@searchProductId" placeholder="VD: 1, 2..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">SKU</label>
                    <input type="text" name="sku" class="form-control form-control-sm" value="@searchSku" placeholder="Mã SKU" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Tên sản phẩm</label>
                    <input type="text" name="productName" class="form-control form-control-sm" value="@searchProductName" placeholder="Tên sản phẩm" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Trạng thái</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">-- Tất cả --</option>
                        <option value="1" selected="@(searchStatus == 1)">Hoạt động</option>
                        <option value="0" selected="@(searchStatus == 0)">Ẩn</option>
                        <option value="2" selected="@(searchStatus == 2)">Nháp</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="bx bx-search me-1"></i> Tìm kiếm</button>
                    @if (searchProductId.HasValue || !string.IsNullOrEmpty(searchSku) || !string.IsNullOrEmpty(searchProductName) || searchStatus.HasValue)
                    {
                        <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-sm btn-outline-secondary ms-1"><i class="bx bx-x me-1"></i> Xóa bộ lọc</a>
                    }
                </div>
            </div>
        </form>
    </div>

    <div class="table-responsive text-nowrap mt-3">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Chuyên mục</th>
                    <th>Thương hiệu</th>
                    <th>Giá gốc</th>
                    <th>Giá KM</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ProductId</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ThumbnailUrl))
                                {
                                    <img src="@item.ThumbnailUrl" alt="thumb" style="width:50px;height:50px;object-fit:cover;" class="rounded" />
                                }
                            </td>
                            <td>@item.ProductName</td>
                            <td>@item.Category?.CategoryName</td>
                            <td>@item.Brand</td>
                            <td>@item.BasePrice.ToString("N0") ₫</td>
                            <td>@(item.DiscountPrice?.ToString("N0") ?? "—") ₫</td>
                            <td>
                                @{
                                    var statusText = item.Status switch
                                    {
                                        1 => "Hoạt động",
                                        0 => "Ẩn",
                                        _ => "Nháp"
                                    };
                                    var statusClass = item.Status switch
                                    {
                                        1 => "bg-label-primary",
                                        0 => "bg-label-dark",
                                        _ => "bg-label-warning"
                                    };
                                }
                                <span class="badge @statusClass me-1">@statusText</span>
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="Products" asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-secondary">Sửa</a>
                                <form asp-area="Admin" asp-controller="Products" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa sản phẩm này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_Pagination.cshtml")
</div>
