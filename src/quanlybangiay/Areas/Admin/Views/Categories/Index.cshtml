@model IEnumerable<quanlybangiay.Models.Category>
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Quản lý chuyên mục";
}

<div class="card">
    <div class="d-flex justify-content-between align-items-center card-header mb-3">
        <h2>Quản lý chuyên mục</h2>
        <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-primary btn-ad-create">Tạo mới</a>
    </div>

    <div class="table-responsive text-nowrap">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tên chuyên mục</th>
                    <th>Slug</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CategoryId</td>
                            <td>@item.CategoryName</td>
                            <td>@item.Slug</td>
                            <td>
                                <span class="badge @(item.IsActive == true ? "bg-label-primary" : "bg-label-dark") me-1">@(item.IsActive == true ? "Hoạt động" : "Không hoạt động")</span>
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="Categories" asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-secondary">Sửa</a>
                                <form asp-area="Admin" asp-controller="Categories" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.CategoryId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa chuyên mục này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_Pagination.cshtml")
</div>

