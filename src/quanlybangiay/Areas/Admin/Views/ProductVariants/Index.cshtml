@model IEnumerable<quanlybangiay.Models.ProductVariant>
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Quản lý biến thể sản phẩm";
    var filterProductId = ViewBag.FilterProductId as int?;
    var filterProductName = ViewBag.FilterProductName as string;
}

<div class="card">
    <div class="d-flex justify-content-between align-items-center card-header mb-3">
        <div>
            <h2>Quản lý biến thể sản phẩm</h2>
            @if (filterProductName != null)
            {
                <span class="text-muted">Sản phẩm: <strong>@filterProductName</strong></span>
            }
        </div>
        <div>
            @if (filterProductId.HasValue)
            {
                <a asp-area="Admin" asp-controller="Products" asp-action="Details" asp-route-id="@filterProductId" class="btn btn-outline-secondary me-2">← Quay lại sản phẩm</a>
                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Create" asp-route-productId="@filterProductId" class="btn btn-primary btn-ad-create">Tạo mới</a>
            }
            else
            {
                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Create" class="btn btn-primary btn-ad-create">Tạo mới</a>
            }
        </div>
    </div>

    <div class="table-responsive text-nowrap">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    @if (!filterProductId.HasValue)
                    {
                        <th>Sản phẩm</th>
                    }
                    <th>SKU</th>
                    <th>Size</th>
                    <th>Màu</th>
                    <th>Mã màu</th>
                    <th>Tồn kho</th>
                    <th>Giá thêm</th>
                    <th>Mặc định</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.VariantId</td>
                            @if (!filterProductId.HasValue)
                            {
                                <td>@(item.Product?.ProductName ?? "—")</td>
                            }
                            <td><strong>@item.SKU</strong></td>
                            <td>@(item.SizeValue ?? "—")</td>
                            <td>@(item.ColorName ?? "—")</td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ColorCode))
                                {
                                    <span style="display:inline-block;width:18px;height:18px;background:@item.ColorCode;border:1px solid #ccc;border-radius:3px;vertical-align:middle;"></span>
                                    @item.ColorCode
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>
                            <td>@item.StockQty</td>
                            <td>@(item.AdditionalPrice?.ToString("N0") ?? "0") ₫</td>
                            <td>
                                <span class="badge @(item.IsDefault ? "bg-label-primary" : "bg-label-dark")">@(item.IsDefault ? "Có" : "Không")</span>
                            </td>
                            <td>
                                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Details" asp-route-id="@item.VariantId" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-area="Admin" asp-controller="ProductVariants" asp-action="Edit" asp-route-id="@item.VariantId" class="btn btn-sm btn-secondary">Sửa</a>
                                <form asp-area="Admin" asp-controller="ProductVariants" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.VariantId" />
                                    @if (filterProductId.HasValue)
                                    {
                                        <input type="hidden" name="productId" value="@filterProductId" />
                                    }
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa biến thể này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="@(filterProductId.HasValue ? 9 : 10)" class="text-center py-4 text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_Pagination.cshtml")
</div>
