@model IEnumerable<quanlybangiay.Models.Post>
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="card">
    <div class="d-flex justify-content-between align-items-center card-header mb-3">
        <h2>Quản lý bài viết</h2>
        <a asp-area="Admin" asp-controller="Posts" asp-action="Create" class="btn btn-primary btn-ad-create">Tạo mới</a>
    </div>

    <div class="table-responsive text-nowrap">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tiêu đề</th>
                    <th>Slug</th>
                    <th>Mô tả ngắn</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.PostId</td>
                            <td>@item.Title</td>
                            <td>@item.Slug</td>
                            <td>@(item.ShortDescription != null && item.ShortDescription.Length > 50 ? item.ShortDescription.Substring(0, 50) + "..." : item.ShortDescription)</td>
                            <td>
                                <span class="badge @(item.IsActive == true ? "bg-label-primary" : "bg-label-dark") me-1">@(item.IsActive == true ? "Hoạt động" : "Không hoạt động")</span>
                            </td>
                            <td>@(item.CreatedAt?.ToString("dd/MM/yyyy HH:mm"))</td>
                            <td>
                                <a asp-area="Admin" asp-controller="Posts" asp-action="Details" asp-route-id="@item.PostId" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-area="Admin" asp-controller="Posts" asp-action="Edit" asp-route-id="@item.PostId" class="btn btn-sm btn-secondary">Sửa</a>
                                <form asp-area="Admin" asp-controller="Posts" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.PostId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa bài viết này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_Pagination.cshtml")
</div>
