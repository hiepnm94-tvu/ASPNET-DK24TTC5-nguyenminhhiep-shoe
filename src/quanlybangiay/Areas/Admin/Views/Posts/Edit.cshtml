@model quanlybangiay.Models.Post

@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Sửa bài viết";
}

<div class="card mb-4">
    <h2 class="card-header fw-bold py-3 mb-4">Sửa bài viết</h2>

    <div class="card-body">
        <form asp-area="Admin" asp-controller="Posts" asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PostId" />
            <div class="mb-3">
                <label class="form-label">Tiêu đề</label>
                <input asp-for="Title" class="form-control" placeholder="Vui lòng nhập tiêu đề" required />
                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <label class="form-label">Slug</label>
                <input asp-for="Slug" class="form-control" placeholder="Vui lòng nhập slug" required />
                @Html.ValidationMessageFor(m => m.Slug, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <label class="form-label">Mô tả ngắn</label>
                <textarea asp-for="ShortDescription" class="form-control" rows="3" placeholder="Vui lòng nhập mô tả ngắn"></textarea>
                @Html.ValidationMessageFor(m => m.ShortDescription, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <label class="form-label">Nội dung</label>
                <textarea asp-for="Content" class="form-control tinymce-editor" rows="8" placeholder="Vui lòng nhập nội dung bài viết"></textarea>
                @Html.ValidationMessageFor(m => m.Content, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <label class="form-label">Ảnh đại diện</label>
                @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
                {
                    <div class="mb-2">
                        <img src="@Model.ThumbnailUrl" style="max-height:100px;max-width:100%;border-radius:6px;" class="border p-1" />
                        <small class="text-muted d-block mt-1">Ảnh hiện tại — tải ảnh mới để thay thế</small>
                    </div>
                }
                <input type="hidden" asp-for="ThumbnailUrl" />
                <input type="file" name="thumbnailFile" class="form-control" accept="image/*"
                       onchange="previewImg(this,'thumb-preview-edit')" />
                <small class="text-muted">Định dạng: jpg, jpeg, png, gif, webp. Tối đa 5MB.</small>
                <div id="thumb-preview-edit" class="mt-2"></div>
            </div>

            <div class="mb-3">
                <label class="form-label">Trạng thái</label>
                <select name="IsActive" class="form-select">
                    <option value="true" selected="@(Model.IsActive == true)">Hoạt động</option>
                    <option value="false" selected="@(Model.IsActive != true)">Không hoạt động</option>
                </select>
            </div>

            <button type="submit" class="btn btn-primary btn-ad-save">Lưu</button>
            <a asp-area="Admin" asp-controller="Posts" asp-action="Index" class="btn btn-outline-secondary btn-ad-cancel">Hủy</a>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_TinyMCE.cshtml")
}