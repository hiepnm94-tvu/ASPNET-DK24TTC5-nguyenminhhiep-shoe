@model quanlybangiay.Models.Order
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Chi tiết đơn hàng";
    var orderItems = ViewBag.OrderItems as List<quanlybangiay.Models.OrderItem> ?? new List<quanlybangiay.Models.OrderItem>();
    var payments = ViewBag.Payments as List<quanlybangiay.Models.Payment> ?? new List<quanlybangiay.Models.Payment>();

    string OrderStatusLabel(byte? status) => status switch
    {
        0 => "Chờ xác nhận",
        1 => "Đã xác nhận",
        2 => "Đang giao",
        3 => "Đã giao",
        4 => "Đã hủy",
        _ => "Không rõ"
    };
    string OrderStatusClass(byte? status) => status switch
    {
        0 => "bg-label-warning",
        1 => "bg-label-info",
        2 => "bg-label-primary",
        3 => "bg-label-success",
        4 => "bg-label-danger",
        _ => "bg-label-dark"
    };
    string PaymentStatusLabel(byte? status) => status switch
    {
        0 => "Chưa thanh toán",
        1 => "Đã thanh toán",
        2 => "Hoàn tiền",
        _ => "Không rõ"
    };
}

<div class="card mb-4">
    <h2 class="card-header fw-bold py-3 mb-4">Chi tiết đơn hàng #@Model.OrderCode</h2>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label fw-bold">Mã đơn hàng</label>
                    <div>@Model.OrderCode</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Khách hàng</label>
                    @if (Model.User != null)
                    {
                        <div>@(Model.User.FullName ?? Model.User.Email) <small class="text-muted">(@Model.User.Email)</small></div>
                    }
                    else
                    {
                        <div>
                            <span class="badge bg-label-secondary me-1">Khách vãng lai</span><br />
                            @if (!string.IsNullOrWhiteSpace(Model.GuestName))
                            {
                                <div><strong>Tên:</strong> @Model.GuestName</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.GuestEmail))
                            {
                                <div><strong>Email:</strong> @Model.GuestEmail</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.GuestPhone))
                            {
                                <div><strong>SĐT:</strong> @Model.GuestPhone</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(Model.GuestAddress))
                            {
                                <div><strong>Địa chỉ:</strong> @Model.GuestAddress</div>
                            }
                        </div>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Trạng thái đơn</label>
                    <div>
                        <span class="badge @OrderStatusClass(Model.OrderStatus)">@OrderStatusLabel(Model.OrderStatus)</span>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Thanh toán</label>
                    <div>
                        <span class="badge @(Model.PaymentStatus == 1 ? "bg-label-success" : "bg-label-warning")">@PaymentStatusLabel(Model.PaymentStatus)</span>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label fw-bold">Tạm tính</label>
                    <div>@Model.Subtotal.ToString("N0") ₫</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Phí vận chuyển</label>
                    <div>@Model.ShippingFee.ToString("N0") ₫</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Giảm giá</label>
                    <div>@Model.DiscountAmount.ToString("N0") ₫</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tổng cộng</label>
                    <div class="fs-5 fw-bold text-primary">@Model.TotalAmount.ToString("N0") ₫</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Ngày đặt</label>
                    <div>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Cập nhật lần cuối</label>
                    <div>@(Model.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Note))
        {
            <div class="mb-3">
                <label class="form-label fw-bold">Ghi chú</label>
                <div>@Model.Note</div>
            </div>
        }
    </div>
</div>

@if (orderItems.Any())
{
    <div class="card mb-4">
        <h5 class="card-header fw-bold py-3">Sản phẩm trong đơn</h5>
        <div class="table-responsive text-nowrap">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Sản phẩm</th>
                        <th>Size</th>
                        <th>Màu</th>
                        <th>Đơn giá</th>
                        <th>Số lượng</th>
                        <th>Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var oi in orderItems)
                    {
                        <tr>
                            <td>@oi.ProductName</td>
                            <td>@(oi.SizeValue ?? "—")</td>
                            <td>@(oi.ColorName ?? "—")</td>
                            <td>@oi.UnitPrice.ToString("N0") ₫</td>
                            <td>@oi.Quantity</td>
                            <td>@oi.LineTotal.ToString("N0") ₫</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (payments.Any())
{
    <div class="card mb-4">
        <h5 class="card-header fw-bold py-3">Lịch sử thanh toán</h5>
        <div class="table-responsive text-nowrap">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Phương thức</th>
                        <th>Mã giao dịch</th>
                        <th>Số tiền</th>
                        <th>Ngày thanh toán</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in payments)
                    {
                        <tr>
                            <td>@p.PaymentId</td>
                            <td>@(p.Method ?? "—")</td>
                            <td>@(p.GatewayTransactionId ?? "—")</td>
                            <td>@p.Amount.ToString("N0") ₫</td>
                            <td>@(p.PaidAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</td>
                            <td>
                                @{
                                    var pStatusText = p.Status switch { 0 => "Chờ", 1 => "Thành công", 2 => "Thất bại", _ => "Không rõ" };
                                    var pStatusClass = p.Status switch { 1 => "bg-label-success", 2 => "bg-label-danger", _ => "bg-label-warning" };
                                }
                                <span class="badge @pStatusClass">@pStatusText</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<a asp-area="Admin" asp-controller="Orders" asp-action="Edit" asp-route-id="@Model.OrderId" class="btn btn-secondary">Cập nhật trạng thái</a>
<a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-outline-secondary">Quay lại</a>
