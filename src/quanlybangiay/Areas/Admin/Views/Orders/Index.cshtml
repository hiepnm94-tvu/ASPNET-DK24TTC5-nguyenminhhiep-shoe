@model IEnumerable<quanlybangiay.Models.Order>
@{
    Layout = "~/Views/Shared/_ManageLayout.cshtml";
    ViewData["Title"] = "Quản lý đơn hàng";
}

@{
    string OrderStatusLabel(byte? status) => status switch
    {
        0 => "Chờ xác nhận",
        1 => "Đã xác nhận",
        2 => "Đang giao",
        3 => "Đã giao",
        4 => "Đã hủy",
        _ => "Không rõ"
    };
    string OrderStatusClass(byte? status) => status switch
    {
        0 => "bg-label-warning",
        1 => "bg-label-info",
        2 => "bg-label-primary",
        3 => "bg-label-success",
        4 => "bg-label-danger",
        _ => "bg-label-dark"
    };
    string PaymentStatusLabel(byte? status) => status switch
    {
        0 => "Chưa thanh toán",
        1 => "Đã thanh toán",
        2 => "Hoàn tiền",
        _ => "Không rõ"
    };
    string PaymentStatusClass(byte? status) => status switch
    {
        0 => "bg-label-warning",
        1 => "bg-label-success",
        2 => "bg-label-danger",
        _ => "bg-label-dark"
    };

    var searchOrderCode = ViewBag.OrderCode as string;
    var searchCustomerName = ViewBag.CustomerName as string;
    byte? searchOrderStatus = ViewBag.OrderStatus as byte?;
    DateTime? searchDateFrom = ViewBag.DateFrom as DateTime?;
    DateTime? searchDateTo = ViewBag.DateTo as DateTime?;
}

<div class="card">
    <div class="d-flex justify-content-between align-items-center card-header mb-0">
        <h2>Quản lý đơn hàng</h2>
        <div class="dropdown">
            <button class="btn btn-outline-success dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="bx bx-export me-1"></i> Xuất dữ liệu
            </button>
            <ul class="dropdown-menu">
                <li><h6 class="dropdown-header">CSV</h6></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Orders" asp-action="Export" asp-route-period="day" asp-route-format="csv">Hôm nay (1 ngày)</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Orders" asp-action="Export" asp-route-period="week" asp-route-format="csv">1 Tuần</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Orders" asp-action="Export" asp-route-period="month" asp-route-format="csv">1 Tháng</a></li>
                <li><hr class="dropdown-divider" /></li>
                <li><h6 class="dropdown-header">JSON</h6></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Orders" asp-action="Export" asp-route-period="day" asp-route-format="json">Hôm nay (1 ngày)</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Orders" asp-action="Export" asp-route-period="week" asp-route-format="json">1 Tuần</a></li>
                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Orders" asp-action="Export" asp-route-period="month" asp-route-format="json">1 Tháng</a></li>
            </ul>
        </div>
    </div>

    <div class="card-body pb-0">
        <form method="get" asp-area="Admin" asp-controller="Orders" asp-action="Index">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="form-label">Mã đơn hàng</label>
                    <input type="text" name="orderCode" class="form-control form-control-sm" value="@searchOrderCode" placeholder="VD: ORD2025..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Khách hàng</label>
                    <input type="text" name="customerName" class="form-control form-control-sm" value="@searchCustomerName" placeholder="Tên khách hàng" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Trạng thái đơn</label>
                    <select name="orderStatus" class="form-select form-select-sm">
                        <option value="">-- Tất cả --</option>
                        <option value="0" selected="@(searchOrderStatus == 0)">Chờ xác nhận</option>
                        <option value="1" selected="@(searchOrderStatus == 1)">Đã xác nhận</option>
                        <option value="2" selected="@(searchOrderStatus == 2)">Đang giao</option>
                        <option value="3" selected="@(searchOrderStatus == 3)">Đã giao</option>
                        <option value="4" selected="@(searchOrderStatus == 4)">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Từ ngày</label>
                    <input type="date" name="dateFrom" class="form-control form-control-sm" value="@(searchDateFrom?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Đến ngày</label>
                    <input type="date" name="dateTo" class="form-control form-control-sm" value="@(searchDateTo?.ToString("yyyy-MM-dd"))" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bx bx-search me-1"></i> Tìm kiếm</button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(searchOrderCode) || !string.IsNullOrEmpty(searchCustomerName) || searchOrderStatus.HasValue || searchDateFrom.HasValue || searchDateTo.HasValue)
            {
                <div class="mt-2">
                    <a asp-area="Admin" asp-controller="Orders" asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bx bx-x me-1"></i> Xóa bộ lọc</a>
                </div>
            }
        </form>
    </div>

    <div class="table-responsive text-nowrap mt-3">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Mã đơn</th>
                    <th>Khách hàng</th>
                    <th>Tổng tiền</th>
                    <th>Trạng thái đơn</th>
                    <th>Thanh toán</th>
                    <th>Ngày đặt</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>@item.OrderCode</strong></td>
                            <td>
                                @if (item.User != null)
                                {
                                    @(item.User.FullName ?? item.User.Email)
                                }
                                else if (!string.IsNullOrWhiteSpace(item.GuestName))
                                {
                                    <span>@item.GuestName</span><br />
                                    <small class="text-muted">@item.GuestPhone</small>
                                }
                                else
                                {
                                    <span class="text-muted">Khách</span>
                                }
                            </td>
                            <td>@item.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                <span class="badge @OrderStatusClass(item.OrderStatus) me-1">@OrderStatusLabel(item.OrderStatus)</span>
                            </td>
                            <td>
                                <span class="badge @PaymentStatusClass(item.PaymentStatus) me-1">@PaymentStatusLabel(item.PaymentStatus)</span>
                            </td>
                            <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-area="Admin" asp-controller="Orders" asp-action="Edit" asp-route-id="@item.OrderId" class="btn btn-sm btn-secondary">Cập nhật</a>
                                <form asp-area="Admin" asp-controller="Orders" asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.OrderId" />
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Bạn muốn xóa đơn hàng này?');">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">Không có dữ liệu</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_Pagination.cshtml")
</div>
